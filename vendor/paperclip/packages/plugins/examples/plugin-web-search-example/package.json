{
  "name": "@paperclipai/plugin-web-search-example",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "First-party Paperclip plugin that exposes a simple public-web search tool for agents.",
  "paperclipPlugin": {
    "manifest": "./dist/src/manifest.js",
    "worker": "./dist/src/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
